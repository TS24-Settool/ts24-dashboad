# ============================================================
# TS24 Dashboard — .gitignore
# NEVER commit files containing API keys or credentials
# ============================================================

# ── Secrets & credentials (NEVER commit these) ──────────────
ts24_config.json
.streamlit/secrets.toml
*.env
.env
*.key
*.pem
secrets.json
config.local.json
*_secret*
*_private*

# ── Streamlit local config ───────────────────────────────────
.streamlit/

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
.pytest_cache/

# ── Database & data files ────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Data files (large / sensitive) ──────────────────────────
*.xlsx
*.csv
*.xls
*.xlsm

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── macOS ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Editor ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~

# ── Claude Code system files ─────────────────────────────────
*.skill
